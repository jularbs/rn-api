# Environment Configuration
NODE_ENV=development
PORT=8000

# Database Configuration
MONGODB_URI="mongodb://<credentials>@host:[port]/[db-name]"

# API Keys (add any API keys you need)
# API_KEY=your_api_key

AWS_ACCESS_KEY_ID=aws-access-key-id-here
AWS_SECRET_ACCESS_KEY=aws-secret-access-key-here
AWS_S3_BUCKET=s3-bucket-name-here
AWS_REGION=aws-region-here

# CORS Settings
ALLOWED_ORIGINS=origins-comma-separated-here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Nodemailer Configuration
SMTP_NAME='Sender Name Here'
SMTP_HOST=smtp-host-here
SMTP_PORT=smtp-port-here
SMTP_SECURE=false
SMTP_USER=smtp-user-here
SMTP_PASS='smtp-pass-here'

MANAGE_DOMAIN=https://cms.example.com
WEB_DOMAIN=https://example.com